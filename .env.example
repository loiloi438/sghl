# Copier ce fichier en .env et adapter les valeurs

DEBUG=True
SECRET_KEY=change-me-en-production
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,0.0.0.0

# --- Production (DEBUG=False) : obligatoire ---
# SECRET_KEY=<50+ caractères aléatoires>
# JWT_SECRET=<distinct de SECRET_KEY>
# PDF_SIGNING_KEY=<distinct de SECRET_KEY>
# ALLOWED_HOSTS=api.votredomaine.com
# CORS_ALLOWED_ORIGINS=https://staff.votredomaine.com
# SECURE_SSL_REDIRECT=True

# Seeds — ne jamais activer en production publique
SGHL_SEED_ADMIN=false
SGHL_SEED_DEMO=false
SGHL_ADMIN_USERNAME=tresormouanga
# Obligatoire si SGHL_SEED_ADMIN=true (setup local / docker dev)
SGHL_ADMIN_PASSWORD=
# SGHL_ADMIN_RESET_PASSWORD=true
# SGHL_ADMIN_RESET_MFA=true

# Dev local : sqlite (laisser DB_ENGINE vide ou sqlite)
# DB_ENGINE=sqlite

# PostgreSQL (production / docker compose)
# DB_ENGINE=postgresql
# DB_NAME=sghl
# DB_USER=sghl
# DB_PASSWORD=sghl
# DB_HOST=localhost
# DB_PORT=5432

# JWT
JWT_SECRET=change-me-jwt-secret
PDF_SIGNING_KEY=change-me-pdf-signing-key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS (production : liste d'origines séparées par des virgules)
# CORS_ALLOWED_ORIGINS=https://staff.example.com

# Limite de connexion (anti brute-force)
LOGIN_RATE_LIMIT_ENABLED=True
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

# Langue
LANGUAGE_CODE=fr-fr
TIME_ZONE=Africa/Brazzaville

# Établissement (PDF)
SGHL_ETABLISSEMENT=SGHL — Centre Hospitalier
SGHL_ADMIN_EMAIL=mouangatresor673@gmail.com
SGHL_SUPPORT_EMAIL=mouangatresor673@gmail.com
SGHL_FRONTEND_URL=http://localhost:5173

# Téléconsultation (salle Jitsi embarquée sur /visio/:token)
SGHL_JITSI_DOMAIN=meet.jit.si
SGHL_JITSI_ROOM_PREFIX=sghl-visio
SGHL_VISIO_EARLY_MINUTES=15
SGHL_VISIO_LATE_MINUTES=15

# E-mails — Gmail (codes MFA admin + validation patient)
EMAIL_NOTIFICATIONS_ENABLED=True
OTP_MODE=production
DEFAULT_FROM_EMAIL=mouangatresor673@gmail.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=mouangatresor673@gmail.com
# Mot de passe d'application Google (pas le mot de passe Gmail) :
# https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Push mobile (FCM legacy API + notifications in-app)
PUSH_NOTIFICATIONS_ENABLED=True
# Clé serveur Firebase Cloud Messaging (Console Firebase → Cloud Messaging)
# FCM_SERVER_KEY=

# --- Payments configuration (examples) -----------------------------------
# Stripe (tests / live keys)
# PAYMENTS_STRIPE_SECRET_KEY=sk_test_replace_me
# PAYMENTS_STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Aggregator / Mobile Money
# PAYMENTS_MTN_AGGREGATOR_URL=https://aggregator.example.com/api
# PAYMENTS_MTN_AGGREGATOR_KEY=replace_me
# PAYMENTS_MTN_FLUTTERWAVE_URL=https://api.flutterwave.com
# PAYMENTS_MTN_FLUTTERWAVE_KEY=replace_me
# PAYMENTS_MTN_WEBHOOK_SECRET=replace_me

# You can define additional provider webhook secrets as needed:
# PAYMENTS_AIRTEL_WEBHOOK_SECRET=replace_me

# Frontend (clé publique Stripe pour le portail patient)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Gmail SMTP example (production/dev with app passwords)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=youremail@gmail.com
# EMAIL_HOST_PASSWORD=replace-with-app-password
# EMAIL_USE_TLS=True

