# Exemple de configuration production SGHL — copier vers .env sur le serveur

DEBUG=False
SECRET_KEY=
JWT_SECRET=
PDF_SIGNING_KEY=
ALLOWED_HOSTS=api.votredomaine.com
CORS_ALLOWED_ORIGINS=https://staff.votredomaine.com
SECURE_SSL_REDIRECT=True

DB_ENGINE=postgresql
# Render : DATABASE_URL est injecté automatiquement (prioritaire sur DB_*)
# DATABASE_URL=postgresql://user:pass@host:5432/sghl
DB_NAME=sghl
DB_USER=sghl
DB_PASSWORD=
DB_HOST=db
DB_PORT=5432

SGHL_FRONTEND_URL=https://staff.votredomaine.com

# Ne jamais activer en production réelle
SGHL_SEED_ADMIN=false
SGHL_SEED_DEMO=false

# Premier déploiement uniquement (puis remettre à false) :
# SGHL_SEED_ADMIN=true
# SGHL_ADMIN_USERNAME=admin
# SGHL_ADMIN_PASSWORD=

PAYMENTS_STRIPE_WEBHOOK_SECRET=
PAYMENTS_MTN_WEBHOOK_SECRET=
